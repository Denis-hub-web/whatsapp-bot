# Server port (Render sets this automatically)
PORT=3000

# Directory to store WhatsApp session credentials
# On Render, use /data/auth_info (persistent disk mounted at /data)
# Locally, use ./auth_info
AUTH_DIR=./auth_info

# MongoDB Connection String (for session persistence on Free Tier)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# API Security (Optional but recommended)
# If set, you must send 'X-API-Key' header in your requests
API_KEY=your_secret_api_key_here
